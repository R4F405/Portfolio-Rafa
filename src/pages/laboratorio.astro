---
import Layout from '../layouts/Layout.astro';
import CardLab from '../components/CardLab.astro';

const experimentosLab = [
    {
        link: "https://github.com/R4F405/google-maps-scrap-automation",
        icono: "📍",
        titulo: "Maps Scraper",
        descripcion: "Automatización de extracción de datos de Google Maps. Recolección de leads B2B y geolocalización de negocios."
    },
    {
        link: "https://github.com/R4F405/MultiScraping",
        icono: "🕵️",
        titulo: "Multi Scrapper",
        descripcion: "Este scrapper sirve para Google Maps mejorado, Instagram y LinkedIn. Todos con proxies y tiempos humanizados. Todo centralizado."
    },
    {
        link: "https://github.com/R4F405/bot-discord-github",
        icono: "🐙",
        titulo: "Git-Discord Sync",
        descripcion: "Integración CI/CD. Webhooks para notificar push, pull requests e issues en canales específicos de desarrollo."
    },
    {
        link: "https://github.com/R4F405/discord-jira-bot",
        icono: "📋",
        titulo: "Jira Agile Bot",
        descripcion: "Puente entre gestión de proyectos y comunicación. Notificaciones de tickets y actualizaciones de sprints directamente en Discord."
    },
    {
        link: "https://github.com/R4F405/bot-discord-youtube",
        icono: "📺",
        titulo: "YouTube Reproductor",
        descripcion: "Reproduce video de YouTube. Reproduce musica desde tu servidor de discord con diversas funciones."
    },
    {
        link: "https://github.com/R4F405/mnist-number-recognition-python",
        icono: "🧠",
        titulo: "MNIST Neural Net",
        descripcion: "Red neuronal clásica para reconocimiento de dígitos manuscritos (0-9). Entrenamiento de modelos con Python y TensorFlow/Keras."
    },
    {
        link: "https://github.com/R4F405/python-stable-diffusion-generator",
        icono: "🎨",
        titulo: "Stable Diffusion Gen",
        descripcion: "Generador de imágenes por IA. Script en Python para interactuar con modelos de difusión estable y crear assets visuales."
    },
    {
        link: "https://github.com/R4F405/flexbot-moderacion-discord",
        icono: "🛡️",
        titulo: "FlexBot Mod",
        descripcion: "Bot de administración de servidores. Comandos de moderación, logs de auditoría y gestión automatizada de roles."
    }
];
---

<Layout title="Laboratorio | Rafa San Pablo">
    <section id="lab" style="padding-top: 150px; min-height: 100vh;">
        <div class="container">
            <h2 class="section-title" style="border-color: var(--neon-accent);">
                Laboratorio <span style="font-size:1rem; color:var(--text-muted)" class="mono-font">// Experimental</span>
            </h2>
            <p style="margin-bottom: 40px; color: #888;">Un espacio donde "rompo cosas" para aprender. Bots, scripts de IA y prototipos rápidos.</p>
            
            <div class="lab-grid">
                {experimentosLab.map((exp) => (
                    <CardLab 
                        link={exp.link}
                        icono={exp.icono}
                        titulo={exp.titulo}
                        descripcion={exp.descripcion}
                    />
                ))}
            </div>
        </div>
    </section>
</Layout>