---
// src/pages/experiencia.astro
import Layout from '../layouts/Layout.astro';
import ItemExperiencia from '../components/ItemExperiencia.astro';
---

<Layout title="Trayectoria | Rafa San Pablo">
    <section id="experience" style="padding-top: 15vh; min-height: 100vh; padding-bottom: 100px;">
        <div class="container" style="max-width: 900px;"> <div style="margin-bottom: 60px;">
                <h2 class="section-title" style="margin-bottom: 10px;">Trayectoria <span style="color: #444;">& Formación</span></h2>
                <p style="color: #888; font-size: 1.1rem;">Mi evolución técnica profesional y académica.</p>
            </div>

            <div style="padding-left: 10px;">
                
                <ItemExperiencia 
                    fecha="2025 - Actualidad"
                    rol="Desarrollador de Software"
                    empresa="Softtalia"
                    ubicacion="Gandia, España"
                    actual={true}
                    colorNeon="var(--neon-primary)"
                >
                    Desarrollo integral de la plataforma <strong>RapidGest</strong>. Implementación de cultura TDD con PestPHP, gestión de infraestructura Docker/Sail y optimización de consultas SQL. Trabajo bajo metodologías ágiles (Scrum/Kanban) asumiendo también la toma de requisitos y el trato directo con el cliente.
                </ItemExperiencia>

                <ItemExperiencia 
                    fecha="2023 - 2025"
                    rol="Desarrollo de Aplicaciones Multiplataforma (DAM)"
                    empresa="Florida Campus Alzira"
                    colorNeon="var(--neon-accent)"
                >
                    Ciclo Formativo de Grado Superior. Especialización en desarrollo backend, arquitectura de software e inicio en el desarrollo de aplicaciones nativas con Java y Kotlin para Android.
                </ItemExperiencia>

                <ItemExperiencia 
                    fecha="2021 - 2023"
                    rol="Técnico en Sistemas Microinformáticos y Redes"
                    empresa="Academia Almi"
                    colorNeon="#00d8ff"
                >
                    Base sólida en administración de sistemas, redes, hardware y fundamentos de infraestructura TI. El punto de partida que me permite comprender la capa de sistemas bajo mi código backend hoy en día.
                </ItemExperiencia>

            </div>
        </div>
    </section>
</Layout>